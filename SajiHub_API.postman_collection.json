				"exec": [
					"// Automatically save the access token to variables when logging in/registering",
					"var jsonData = pm.response.json();",
					"if (jsonData && jsonData.access_token) {",
					"    pm.collectionVariables.set(\"access_token\", jsonData.access_token);",
					"}"
				]
			}
		}
